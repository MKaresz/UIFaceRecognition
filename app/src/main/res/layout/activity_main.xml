<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Spinner
        android:id="@+id/SpinnerMenu"
        android:layout_width="357dp"
        android:layout_height="36dp"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ImageView"
        android:layout_width="357dp"
        android:layout_height="345dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toTopOf="@+id/ResultText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.481"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/SpinnerMenu"
        app:layout_constraintVertical_bias="0.489"
        app:srcCompat="@drawable/ic_launcher_background" />

    <TextView
        android:id="@+id/ResultText"
        android:layout_width="357dp"
        android:layout_height="110dp"
        android:scrollbars="vertical"
        android:layout_marginBottom="16dp"
        android:gravity="top|left"
        android:text=""
        android:textSize="15dp"
        android:tooltipText="Result"
        app:layout_constraintBottom_toTopOf="@+id/btn_takePicture"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_takePicture"
        android:layout_width="158dp"
        android:layout_height="47dp"
        android:layout_marginBottom="20dp"
        android:text="Take Picture"
        app:layout_constraintBottom_toTopOf="@+id/DebugText"
        app:layout_constraintEnd_toStartOf="@+id/EvalButton"
        app:layout_constraintHorizontal_bias="0.549"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/DebugText"
        android:layout_width="390dp"
        android:layout_height="62dp"
        android:layout_marginBottom="16dp"
        android:text="debug"
        android:textAlignment="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.476"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/EvalButton"
        android:layout_width="158dp"
        android:layout_height="46dp"
        android:layout_marginEnd="28dp"
        android:text="Evaluate"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@+id/DebugText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ResultText"
        app:layout_constraintVertical_bias="0.432" />

</androidx.constraintlayout.widget.ConstraintLayout>